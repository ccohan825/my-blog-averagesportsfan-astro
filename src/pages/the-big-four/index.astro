---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

import '../../styles/home.css';
import '../../styles/mobile.css';

const posts = (
  await getCollection(
    'blog',
    ({ data }) =>
      data.draft !== true &&
      data.category === 'The Big Four'
  )
).sort(
  (a, b) =>
    b.data.pubDate.getTime() -
    a.data.pubDate.getTime()
);
---

<BaseLayout
  title="The Big Four | Average Sports Fan"
  description="Baseball, hockey, the NBA, the W, golf, and everything outside football from Average Sports Fan."
>
  <main class="page-wrap category-page">
    <section class="category-intro">
      <div class="hero-kicker">Beyond Football</div>

      <h1>The Big Four</h1>

      <p>
        I do like writing about things besides football, so here’s where all
        my takes on baseball, hockey, the NBA, the W, and maybe some golf
        sprinkled in too.
      </p>
    </section>

    <h2 class="section-title">
      <span>Latest Big Four Blogs</span>
    </h2>

    <section class="blog-grid">
      {
        posts.length === 0 ? (
          <div class="empty-posts">
            No Big Four blogs have been published yet.
          </div>
        ) : (
          posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              pubDate={post.data.pubDate}
              href={`/blogs/${post.id}/`}
              image={post.data.heroImage}
              imageAlt={post.data.heroImageAlt}
            />
          ))
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .category-page {
    padding-bottom: 40px;
  }

  .category-intro {
    margin-top: 30px;
    padding: 52px 60px;
    border-radius: 14px;
    background:
      radial-gradient(
        circle at 80% 30%,
        rgb(215 25 32 / 34%),
        transparent 32%
      ),
      linear-gradient(
        135deg,
        var(--navy),
        var(--blue)
      );
    color: var(--white);
    box-shadow: var(--card-shadow);
  }

  .category-intro h1 {
    margin: 12px 0;
    font-family: Impact, "Arial Black", sans-serif;
    font-size: clamp(48px, 8vw, 86px);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .category-intro p {
    max-width: 760px;
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.5;
  }

  @media (max-width: 700px) {
    .category-intro {
      padding: 38px 24px;
      text-align: center;
    }
  }
</style>