---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

import '../styles/home.css';
import '../styles/mobile.css';

const posts = await getCollection(
  'blog',
  ({ data }) => data.draft !== true
);

const latestPosts = posts
  .sort(
    (a, b) =>
      b.data.pubDate.valueOf() -
      a.data.pubDate.valueOf()
  )
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Average Sports Fan | NFL & College Football Blog"
  description="Average Sports Fan covers NFL and college football with fan reactions, rankings, and hot takes."
>
  <section class="brand-strip">
    <img
      src="/images/red-brush.png"
      class="corner-brush brush-red-left"
      alt=""
    />

    <img
      src="/images/blue-brush.png"
      class="corner-brush brush-blue-left"
      alt=""
    />

    <img
      src="/images/blue-brush.png"
      class="corner-brush brush-blue-right"
      alt=""
    />

    <img
      src="/images/red-brush.png"
      class="corner-brush brush-red-right"
      alt=""
    />

    <div class="brand-content">
      <div class="brand-side left">
        <img
          src="/images/falling-fan.png"
          class="brand-character falling-fan-img"
          alt="Average Sports Fan diving for a football"
        />

        <div class="callout left">
          <span class="navy">Not experts.</span>
          <span class="red">Just fans.</span>
        </div>
      </div>

      <img
        src="/images/logo.png"
        class="brand-logo"
        alt="Average Sports Fan logo"
      />

      <div class="brand-side right">
        <div class="callout right">
          <span class="navy">Hot takes.</span>
          <span class="red">Cold beers.</span>
          <span class="navy">Chaos.</span>
        </div>

        <img
          src="/images/fan.png"
          class="brand-character standing-fan-img"
          alt="Average Sports Fan cartoon fan"
        />
      </div>
    </div>

    <div class="brand-slogan">
      Real Fans. Real Opinions. <span>Zero Filter.</span>
    </div>
  </section>

  <main class="page-wrap">
    <section class="hero-card">
      <div class="hero-copy">
        <div class="hero-kicker">
          NFL • College Football • Fan Reactions
        </div>

        <h1>
          Football
          <span>From the Fan Perspective</span>
        </h1>

        <p>
          We cover the NFL and college football through the eyes of fans:
          rankings, reactions, hot takes, and all the chaos in between.
        </p>

        <a class="primary-button" href="/blogs/">
          Dive Into the Chaos →
        </a>
      </div>
    </section>

    <h2 class="section-title">
      <span>Latest Blogs</span>
    </h2>

    <section class="blog-grid" id="latest-posts">
      {
        latestPosts.length === 0 ? (
          <div class="empty-posts">
            No blogs published yet.
          </div>
        ) : (
          latestPosts.map((post) => (
            <article class="post-card">
              <div class="post-tag">
                {post.data.category}
              </div>

              <time
                class="post-date"
                datetime={post.data.pubDate.toISOString()}
              >
                {formatDate(post.data.pubDate)}
              </time>

              <h3>{post.data.title}</h3>

              <p>{post.data.description}</p>

              <a href={`/blogs/${post.id}/`}>
                Read Article →
              </a>
            </article>
          ))
        )
      }
    </section>

    <section class="email-strip">
      <div>
        <h2>Join the ASF Crew</h2>

        <p>
          Get hot takes, blog drops, and chaos straight to your inbox.
        </p>
      </div>

      <div class="kit-form-box">
        <script
          is:inline
          async
          data-uid="f203890c32"
          src="https://average-sports-fan.kit.com/f203890c32/index.js"
        ></script>
      </div>
    </section>
  </main>
</BaseLayout>