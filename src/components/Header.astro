---
const currentPath = Astro.url.pathname;

const navigation = [
  {
    label: 'Home',
    href: '/',
  },
  {
    label: 'Blogs',
    href: '/blogs/',
  },
  {
    label: 'NFL',
    href: '/nfl/',
  },
  {
    label: 'College Football',
    href: '/college-football/',
  },
];

function isActive(href: string) {
  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-container header-inner">
    <a class="site-logo" href="/" aria-label="Average Sports Fan homepage">
      <img
        src="/images/logo.png"
        alt="Average Sports Fan"
        width="80"
        height="80"
      />

      <span>Average Sports Fan</span>
    </a>

    <nav aria-label="Main navigation">
      <ul class="navigation-list">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={{
                  'navigation-link': true,
                  active: isActive(item.href),
                }}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-navy);
    color: var(--color-white);
    border-bottom: 4px solid var(--color-red);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    min-height: 92px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    color: inherit;
    font-size: 1.25rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-logo img {
    width: 64px;
    height: 64px;
    object-fit: contain;
  }

  .navigation-list {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .navigation-link {
    display: block;
    padding: 12px 14px;
    border-radius: 4px;
    color: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
  }

  .navigation-link:hover,
  .navigation-link.active {
    background: var(--color-red);
  }

  @media (max-width: 760px) {
    .header-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      padding: 12px 0;
    }

    .site-logo {
      justify-content: center;
    }

    .navigation-list {
      justify-content: center;
      flex-wrap: wrap;
    }

    .navigation-link {
      padding: 8px 10px;
      font-size: 0.85rem;
    }
  }
</style>