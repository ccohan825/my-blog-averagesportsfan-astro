---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-container footer-inner">
    <div>
      <strong>Average Sports Fan</strong>

      <p>
        NFL and college football commentary for regular fans who take sports
        too seriously.
      </p>
    </div>

    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/blogs/">Blogs</a>
      <a href="/nfl/">NFL</a>
      <a href="/college-football/">College Football</a>
    </div>
  </div>

  <div class="copyright">
    © {currentYear} Average Sports Fan
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy);
    color: var(--color-white);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
    padding: 48px 0;
  }

  .footer-inner p {
    max-width: 600px;
    color: #d8e1eb;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .footer-links a {
    color: inherit;
    text-decoration: none;
  }

  .footer-links a:hover {
    text-decoration: underline;
  }

  .copyright {
    padding: 16px;
    border-top: 1px solid rgb(255 255 255 / 15%);
    text-align: center;
    color: #d8e1eb;
    font-size: 0.875rem;
  }

  @media (max-width: 700px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>