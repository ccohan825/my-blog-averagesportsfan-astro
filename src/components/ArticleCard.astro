---
interface Props {
  title: string;
  description: string;
  category: string;
  pubDate: Date;
  href: string;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  category,
  pubDate,
  href,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <div class="post-tag">
    {category}
  </div>

  <time
    class="post-date"
    datetime={pubDate.toISOString()}
  >
    {formattedDate}
  </time>

  <h3>{title}</h3>

  <p>{description}</p>

  <a href={href}>
    Read Article →
  </a>
</article>